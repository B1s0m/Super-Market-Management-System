<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        <%= category.name %>
    </title>

    <link rel="stylesheet" href="/css/customer/subcategoryview.css">
    <link rel="stylesheet" href="/css/customer/navbar.css">

</head>

<body>


    <%- include('../partials/customer/navbar') %>

        <main class="page-container">


            <div class="breadcrumb">

                <a href="/homepage">
                    Home
                </a>

                <span>></span>

                <span>
                    <%= category.name %>
                </span>

            </div>



            <section class="category-header">

                <div>
                    <p class="category-label">
                        Shop Category
                    </p>

                    <h1>
                        <%= category.name %>
                    </h1>

                    <p class="product-count">
                        <%= totalProducts %>
                            <%= products.length===1 ? "product" : "products" %>
                                available
                    </p>
                </div>

            </section>


            <section class="    -section">




                <div class="subcategory-list">

                    <a href="/categoryviews/<%= category._id %>" class="subcategory-card active">

                        <span>
                            All Products
                        </span>
                    </a>


                    <% subcategories.forEach(subcategory=> { %>

                        <a href="#" class="subcategory-card">

                            <span>
                                <%= subcategory.name %>
                            </span>
                        </a>

                        <% }) %>

                </div>

            </section>



            <section class="products-section">



                <% if (products.length> 0) { %>

                    <div class="products-grid">

                        <% products.forEach(product=> { %>

                            <article class="product-card">

                                <a href="/details/<%= product._id %>" class="product-image-link">

                                    <% if ( product.variants && product.variants.length> 0 &&
                                        product.variants[0].image
                                        ) { %>

                                        <img src="/image/product/<%= product.variants[0].image %>"
                                            alt="<%= product.name %>" class="product-image">

                                        <% } else if (product.image) { %>

                                            <img src="/image/product/<%= product.image %>" alt="<%= product.name %>"
                                                class="product-image">

                                            <% } else { %>

                                                <div class="no-image">
                                                    No Image
                                                </div>

                                                <% } %>

                                </a>



                                <div class="product-content">

                                    <p class="product-subcategory">
                                        <%= product.subcategory?.name || "Other" %>
                                    </p>


                                    <a href="/details/<%= product._id %>" class="product-name">
                                        <%= product.name %>
                                    </a>


                                    <p class="product-brand">
                                        Brand:
                                        <span>
                                            <%= product.brand || "Unknown" %>
                                        </span>
                                    </p>



                                    <div class="price-row">


                                        <% // some opeartion for take price and discount const
                                            variantPrices=product.variants.map((variant)=> Number(variant.price))

                                            // this like Math.min( variantPrices[0] ,variantPrices[1],..)
                                            const cheapestPrice = variantPrices.length > 0 ? Math.min(...variantPrices)
                                            : 0;

                                            const finalPrice = cheapestPrice - (cheapestPrice * product.discount / 100);

                                            const variantquantity=product.variants .map((variant)=> Number(variant.quantity))

                                             const cheapestquantity = variantquantity.length > 0 ? Math.min(...variantquantity)
                                            : 0;
         





                                            %>
                                            <div>
                                                <% if ( product.discount && product.discount> 0
                                                    ) { %>

                                                    <span class="old-price">
                                                        <%= cheapestPrice.toFixed(2) %> BHD
                                                    </span>

                                                    <p class="product-price">
                                                        <%= finalPrice.toFixed(2) %> BHD
                                                    </p>

                                                    <% } else { %>

                                                        <p class="product-price">
                                                            <%= cheapestPrice.toFixed(2) %> BHD
                                                        </p>

                                                        <% } %>
                                            </div>


                                            <% if (cheapestquantity> 0) { %>

                                                <span class="stock available">
                                                    In Stock
                                                </span>

                                                <% } else { %>

                                                    <span class="stock unavailable">
                                                        Out of Stock
                                                    </span>

                                                    <% } %>

                                    </div>


                                    <a href="/details/<%= product._id %>" class="view-button">
                                        View Product
                                    </a>

                                </div>

                            </article>

                            <% }) %>

                    </div>

                    <% } else { %>

                        <div class="empty-products">

                            <h3>
                                No products found
                            </h3>

                            <a href="/homepage">
                                Return to Homepage
                            </a>

                        </div>

                        <% } %>

            </section>

                  
            <div class="pagination">

                <% if(page> 1){ %>
                    <a href="?page=<%= page-1 %>">Previous</a>
                    <% } %>

                        <% for(let i=1; i <=totalPages; i++){ %>

                            <a href="?page=<%= i %>" class="<%= page === i ? 'active' : '' %>">
                                <%= i %>
                            </a>

                            <% } %>

                                <% if(page < totalPages){ %>
                                    <a href="?page=<%= page+1 %>">Next</a>
                                    <% } %>

            </div>
        </main>

</body>

</html>