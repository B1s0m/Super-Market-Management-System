<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">

    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>
        <%= category.name %>
    </title>

    <link rel="stylesheet" href="/css/customer/subcategoryview.css">
    <link rel="stylesheet" href="/css/customer/navbar.css">

</head>

<body>


    <%- include('../partials/customer/navbar') %>

        <main class="page-container">

        
            <div class="breadcrumb">

                <a href="/homepage">
                    Home
                </a>

                <span>></span>

                <span>
                    <%= category.name %>
                </span>

            </div>


          
            <section class="category-header">

                <div>
                    <p class="category-label">
                        Shop Category
                    </p>

                    <h1>
                        <%= category.name %>
                    </h1>

                    <p class="product-count">
                        <%= products.length %>
                            <%= products.length===1 ? "product" : "products" %>
                                available
                    </p>
                </div>

            </section>


            <section class="subcategory-section">

                


                <div class="subcategory-list">

                    <a href="/categoryviews/<%= category._id %>" class="subcategory-card active">
                      
                        <span>
                            All Products
                        </span>
                    </a>


                    <% subcategories.forEach(subcategory=> { %>

                        <a href="/subcategoryviews/<%= subcategory._id %>" class="subcategory-card">
                            
                            <span>
                                <%= subcategory.name %>
                            </span>
                        </a>

                        <% }) %>

                </div>

            </section>


           
            <section class="products-section">

            

                <% if (products.length> 0) { %>

                    <div class="products-grid">

                        <% products.forEach(product=> { %>

                            <article class="product-card">

                                <a href="/products/details/<%= product._id %>" class="product-image-link">

                                    <% if ( product.variants && product.variants.length> 0 &&
                                        product.variants[0].image
                                        ) { %>

                                        <img src="/image/product/<%= product.variants[0].image %>"
                                            alt="<%= product.name %>" class="product-image">

                                        <% } else if (product.image) { %>

                                            <img src="/image/product/<%= product.image %>" alt="<%= product.name %>"
                                                class="product-image">

                                            <% } else { %>

                                                <div class="no-image">
                                                    No Image
                                                </div>

                                                <% } %>

                                </a>


                                <div class="product-content">

                                    <p class="product-subcategory">
                                        <%= product.subcategory?.name || "Other" %>
                                    </p>


                                    <a href="/products/details/<%= product._id %>" class="product-name">
                                        <%= product.name %>
                                    </a>


                                    <p class="product-brand">
                                        Brand:
                                        <span>
                                            <%= product.brand || "Unknown" %>
                                        </span>
                                    </p>


                                    <div class="price-row">

                                        <div>
                                            <% if ( product.discount && product.discount> 0
                                                ) { %>

                                                <span class="old-price">
                                                    $<%= Number(product.price || 0).toFixed(2) %> </span>

                                                <p class="product-price">
                                                    $<%= ( product.price - product.price * product.discount / 100
                                                        ).toFixed(2) %>
                                                </p>

                                                <% } else { %>

                                                    <p class="product-price">
                                                        $<%= Number(product.price || 0).toFixed(2) %>
                                                    </p>

                                                    <% } %>
                                        </div>


                                        <% if (product.quantity> 0) { %>

                                            <span class="stock available">
                                                In Stock
                                            </span>

                                            <% } else { %>

                                                <span class="stock unavailable">
                                                    Out of Stock
                                                </span>

                                                <% } %>

                                    </div>


                                    <a href="/products/details/<%= product._id %>" class="view-button">
                                        View Product
                                    </a>

                                </div>

                            </article>

                            <% }) %>

                    </div>

                    <% } else { %>

                        <div class="empty-products">

                            <div class="empty-icon">
                                📦
                            </div>

                            <h3>
                                No products found
                            </h3>

                            <p>
                                There are currently no products available
                                in this category.
                            </p>

                            <a href="/homepage">
                                Return to Homepage
                            </a>

                        </div>

                        <% } %>

            </section>

        </main>

</body>

</html>