<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/createparodect.css">
    <title>Document</title>
</head>

<body>
    <%- include('../partials/employee/navbar') %>
        <div class="container">
        <h1> page create Prodect</h1>
        <form action="/products/new" method="post">

            <label for="name">Nmae:</label>
            <input id="name" type="text" name="name" required>

            <label for="category">Category</label>
            <select name="category">
                <option>Fruits</option>
                <option>Vegetables</option>
                <option>Dairy</option>
                <option>Bakery</option>
                <option>Beverages</option>
                <option>Snacks</option>
                <option>Frozen Foods</option>

                <option>Electronics</option>
                <option>Mobile Phones</option>
                <option>Laptops</option>
                <option>Computers</option>
                <option>Tablets</option>
                <option>TV &amp; Audio</option>
                <option>Gaming</option>
                <option>Cameras</option>
                <option>Smart Watches</option>
                <option>Accessories</option>

                <option>Home Appliances</option>

                <option>Clothing</option>
                <option>Books</option>
                <option>Toys</option>

                <option>Other</option>
            </select>


            <label for="brand">brand:</label>
            <input id="brand" type="text" name="brand" >

            <label for="price">price:</label>
            <input id="price" type="number" name="price"    step="0.01" required>

            <label for="discount">discount:</label>
            <input id="discount" type="number" name="discount" >


            <label for="image">image:</label>
            <input id="image" type="text" name="image" >

            <label for="quantity">Quantity:</label>
            <input id="quantity" type="number" name="quantity" required>

            <label for="description">Description</label>
            <textarea id="content" name="description" ></textarea>
                    <button type="submit">create parodect</button>
        </form>
        </div>
</body>

</html>