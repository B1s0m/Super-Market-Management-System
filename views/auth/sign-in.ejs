<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign In</title>

    <link rel="stylesheet" href="/css/signin.css">
</head>
<body>

    <div class="container">

        <div class="login-card">

            <h1>Welcome Back</h1>
            <p>Sign in to continue shopping.</p>

            <form action="/auth/sign-in" method="POST">

                <label for="username">Username</label>
                <input
                    type="text"
                    id="username"
                    name="username"
                    placeholder="Enter your username"
                    required
                >

                <label for="password">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    placeholder="Enter your password"
                    required
                >

                <button type="submit">
                    Sign In
                </button>

            </form>

            <div class="links">

                <a href="/auth/sign-up">
                    📝 Create Account
                </a>

                <a href="/homepage">
                    Continue as Guest
                </a>

            </div>

        </div>

    </div>

</body>
</html>